  </link>
  <joint name="front_right_wheel" type="continuous">
    <parent link="front_right_steer_link" />
    <child link="front_right_wheel_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="rear_left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.0 0.0 0.0 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002" />
    </inertial>
  </link>
  <joint name="rear_left_wheel" type="continuous">
    <parent link="base_link" />
    <child link="rear_left_wheel_link" />
    <origin xyz="-1.60 0.50 0.12" rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="rear_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.0 0.0 0.0 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002" />
    </inertial>
  </link>
  <joint name="rear_right_wheel" type="continuous">
    <parent link="base_link" />
    <child link="rear_right_wheel_link" />
    <origin xyz="-1.60 -0.50 0.12" rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <joint name="hitch" type="revolute">
    <parent link="base_link" />
    <child link="trailer_link" />
    <origin xyz="-2.3 0 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-2.0944" upper="2.0944" effort="0" velocity="10" />
  </joint>

  <link name="trailer_link">
    <visual>
      <origin xyz="-1.5 0 0.15" rpy="0 0 0" />
      <geometry>
        <box size="3.4 1.4 0.3" />
      </geometry>
      <material name="chassis_red">
        <color rgba="1.0 0.0 0.0 1.0" />
