<?xml version="1.0"?>
<robot name="tractor_trailer">
  <link name="base_link">
    <visual>
      <origin xyz="-0.075 0 0.15" rpy="0 0 0" />
      <geometry>
        <box size="3.85 1.4 0.32" />
      </geometry>
      <material name="chassis_blue">
        <color rgba="0.15 0.38 0.85 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0.075 0 0.15" rpy="0 0 0" />
      <geometry>
        <box size="3.85 1.4 0.32" />
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0" />
      <origin xyz="0 0 0.15" rpy="0 0 0" />
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
    </inertial>
  </link>

  <link name="front_left_steer_link">
    <inertial>
      <mass value="0.05" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>
  <joint name="front_left_steer" type="revolute">
    <parent link="base_link" />
    <child link="front_left_steer_link" />
    <origin xyz="1.45 0.50 0.12" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.8" upper="0.8" effort="1" velocity="5" />
  </joint>

  <link name="front_left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.0 0.0 0.0 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002" />
    </inertial>
  </link>
  <joint name="front_left_wheel" type="continuous">
    <parent link="front_left_steer_link" />
    <child link="front_left_wheel_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="front_right_steer_link">
    <inertial>
      <mass value="0.05" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>
  <joint name="front_right_steer" type="revolute">
    <parent link="base_link" />
    <child link="front_right_steer_link" />
    <origin xyz="1.45 -0.50 0.12" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.8" upper="0.8" effort="1" velocity="5" />
  </joint>

  <link name="front_right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.0 0.0 0.0 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.33" length="0.14" />
      </geometry>
