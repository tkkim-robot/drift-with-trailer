      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002" />
    </inertial>
  </link>
  <joint name="trailer_left_wheel" type="continuous">
    <parent link="trailer_link" />
    <child link="trailer_left_wheel_link" />
    <origin xyz="-2.5 0.50 0.12" rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="trailer_right_wheel_link">
